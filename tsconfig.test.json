{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "outDir": "out",
    "lib": ["ES2019"],
    "sourceMap": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": [
    "src/shared/sql-splitter.ts",
    "src/shared/sql-formatter.ts",
    "src/shared/sql-linter.ts",
    "src/schema-diff/schema-diff.ts",
    "src/bookmarks/bookmark-provider.ts",
    "src/query-history/query-history-provider.ts",
    "src/copilot/schema-context.ts",
    "src/interfaces/**/*.ts",
    "src/test/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
